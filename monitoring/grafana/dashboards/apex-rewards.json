{
  "title": "ApexRewards Overview",
  "uid": "apex-rewards-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["apex-rewards", "stellar", "apex"],
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"apex-backend\"}[5m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "API Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"apex-backend\",status=~\"5..\"}[5m])",
          "legendFormat": "5xx errors"
        }
      ]
    },
    {
      "id": 3,
      "title": "APEX Token Transfers (24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "increase(apex_token_transfers_total[24h])",
          "legendFormat": "Transfers"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Reward Programs",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "apex_active_reward_programs",
          "legendFormat": "Programs"
        }
      ]
    },
    {
      "id": 5,
      "title": "DB Connections",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"apexrewards\"}",
          "legendFormat": "Connections"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "Redis Memory Usage",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100",
          "legendFormat": "Memory %"
        }
      ]
    },
    {
      "id": 7,
      "title": "Stellar RPC Latency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(stellar_rpc_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(stellar_rpc_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ]
    }
  ]
}
