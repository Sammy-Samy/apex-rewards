# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME=ApexRewards

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://apex:apex_secret@localhost:5432/apexrewards
DB_HOST=localhost
DB_PORT=5432
DB_NAME=apexrewards
DB_USER=apex
DB_PASSWORD=apex_secret

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=change_me_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ─── Stellar ───────────────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_ADMIN_SECRET_KEY=S...
STELLAR_APEX_CONTRACT_ID=C...

# ─── APEX Token ────────────────────────────────────────────────────────────────
APEX_TOKEN_ISSUER=G...
APEX_TOKEN_CODE=APEX

# ─── Frontend (public) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_APEX_CONTRACT_ID=C...

# ─── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# ─── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@apexrewards.app
SMTP_PASSWORD=change_me_smtp
